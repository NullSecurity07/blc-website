# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# SMTP — your mail server settings
# For Gmail: host=smtp.gmail.com, port=587, secure=false, user=your@gmail.com, pass=app-password
# For your own server: host=mail.yourdomain.com, port=587, user=info@blcompiler.com, pass=...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where contact form submissions are delivered
CONTACT_EMAIL=info@blcompiler.com
